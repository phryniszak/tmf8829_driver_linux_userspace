{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: configure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "zip",
            "type": "shell",
            "command": "zip",
            "args": [
                "-r",
                "${workspaceFolderBasename}.zip",
                "${workspaceFolder}",
                "-x",
                "*/build/*"
            ],
            "problemMatcher": []
        },
        {
            "label": "Stream: websocketd",
            "type": "shell",
            "command": "websocketd",
            "args": [
                "--port=8080",
                "--staticdir=${workspaceFolder}/tools_stream",
                "${workspaceFolder}/build/tmf8829",
                "-m",
                "-t",
                "0",
                "--stream"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
    ]
}